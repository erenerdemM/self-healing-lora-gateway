<?xml version="1.0" encoding="UTF-8"?>
<!-- network-config-mid.xml  —  MidScale (10 GW, 5000×5000 m) IP Konfigürasyonu -->
<config>
    <!-- LoRaGWNic: sadece IP ata -->
    <interface hosts="**" names="LoRaGWNic"
               address="10.99.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- LoRaNic: EndNode LoRa arabirimi -->
    <interface hosts="**" names="LoRaNic"
               address="10.98.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- WLAN: MeshNode kablosuz -->
    <interface hosts="LoraMeshNetworkMid.meshNode*" names="wlan0"
               address="10.97.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW1 – Router eth0  (10.1.1.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW1"  names="eth0" address="10.1.1.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth0" address="10.1.1.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW2 – Router eth1  (10.1.2.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW2"  names="eth0" address="10.1.2.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth1" address="10.1.2.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW3 – Router eth2  (10.1.3.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW3"  names="eth0" address="10.1.3.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth2" address="10.1.3.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW4 – Router eth3  (10.1.4.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW4"  names="eth0" address="10.1.4.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth3" address="10.1.4.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW5 – Router eth4  (10.1.5.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW5"  names="eth0" address="10.1.5.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth4" address="10.1.5.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW6 – Router eth5  (10.1.6.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW6"  names="eth0" address="10.1.6.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth5" address="10.1.6.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

