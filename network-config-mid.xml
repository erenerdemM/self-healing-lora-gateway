    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth6" address="10.1.7.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW8 – Router eth7  (10.1.8.0/30) -->
