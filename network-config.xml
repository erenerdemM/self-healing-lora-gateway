<?xml version="1.0" encoding="UTF-8"?>
<config>
    <!-- LoRaGWNic: HybridGateway LoRa alici/verici. Sadece IP ata, rota yok. -->
    <interface hosts="**" names="LoRaGWNic"
               address="10.99.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- LoRaNic: EndNode LoRa arabirimi. Sadece IP ata, rota yok. -->
    <interface hosts="**" names="LoRaNic"
               address="10.98.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- WLAN: MeshNode kablosuz arabirim. Sadece IP ata, rota yok. -->
    <interface hosts="LoraMeshNetwork.meshNode*" names="wlan0"
               address="10.97.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- Backhaul link 1: hybridGW1.eth0 - gwRouter1.eth0 (10.1.1.0/30) -->
    <interface hosts="LoraMeshNetwork.hybridGW1" names="eth0"
               address="10.1.1.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetwork.gwRouter1" names="eth0"
               address="10.1.1.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- Backhaul link 2: hybridGW2.eth0 - gwRouter1.eth1 (10.1.2.0/30) -->
    <interface hosts="LoraMeshNetwork.hybridGW2" names="eth0"
               address="10.1.2.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetwork.gwRouter1" names="eth1"
               address="10.1.2.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- Backhaul link 3: hybridGW3.eth0 - gwRouter1.eth2 (10.1.3.0/30) -->
    <interface hosts="LoraMeshNetwork.hybridGW3" names="eth0"
               address="10.1.3.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetwork.gwRouter1" names="eth2"
               address="10.1.3.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- Backhaul link 4: gwRouter1.eth3 - networkServer.eth0 (10.1.4.0/30) -->
    <interface hosts="LoraMeshNetwork.gwRouter1" names="eth3"
               address="10.1.4.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetwork.networkServer" names="eth0"
               address="10.1.4.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- Varsayilan rotalar: GW ve server trafiklerini gwRouter1 uzerinden iletir -->
    <route hosts="LoraMeshNetwork.hybridGW1"
           destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetwork.hybridGW2"
           destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetwork.hybridGW3"
           destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetwork.networkServer"
           destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
</config>
