    <!-- GW10 – Router eth9  (10.1.10.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW10"  names="eth0" address="10.1.10.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth9" address="10.1.10.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- gwRouter1 → NetworkServer -->
    <interface hosts="LoraMeshNetworkMid.gwRouter1"       names="eth10" address="10.50.0.1" netmask="255.255.255.0" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkMid.networkServer"   names="eth0"        address="10.50.0.2" netmask="255.255.255.0" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
</config>
