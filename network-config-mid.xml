    <interface hosts="LoraMeshNetworkMid.gwRouter1"  names="eth7" address="10.1.8.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW9 – Router eth8  (10.1.9.0/30) -->
    <interface hosts="LoraMeshNetworkMid.hybridGW9"  names="eth0" address="10.1.9.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
