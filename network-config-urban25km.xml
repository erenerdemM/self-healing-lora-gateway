<?xml version="1.0" encoding="UTF-8"?>
<!-- network-config-urban25km.xml
     Urban25km: 4 HybridGateway, 8 MeshNode, 20 SensorNode
     Alan: 5000x5000 m  |  SF10/EU868  |  gamma=4.0 (kentsel)
     IP şeması (Mid ile tutarlı):
       LoRaGWNic : 10.99.0.x/24
       LoRaNic   : 10.98.0.x/24
       WLAN      : 10.97.0.x/24
       GW-Router : 10.1.{1-4}.0/30
       NS link   : 10.50.0.0/24
-->
<config>
    <!-- LoRaGWNic: sadece IP ata, rota ekleme -->
    <interface hosts="**" names="LoRaGWNic"
               address="10.99.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- LoRaNic: EndNode (sensor) LoRa arayüzü -->
    <interface hosts="**" names="LoRaNic"
               address="10.98.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- WLAN: MeshNode IEEE 802.11 arayüzü -->
    <interface hosts="LoraMeshNetworkUrban25km.meshNode*" names="wlan0"
               address="10.97.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW1 – Router eth0  (10.1.1.0/30)  quadrant SW: (1250,1250) -->
    <interface hosts="LoraMeshNetworkUrban25km.hybridGW1" names="eth0"
               address="10.1.1.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkUrban25km.gwRouter1" names="eth0"
               address="10.1.1.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW2 – Router eth1  (10.1.2.0/30)  quadrant SE: (3750,1250) -->
    <interface hosts="LoraMeshNetworkUrban25km.hybridGW2" names="eth0"
               address="10.1.2.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkUrban25km.gwRouter1" names="eth1"
               address="10.1.2.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW3 – Router eth2  (10.1.3.0/30)  quadrant NW: (1250,3750) -->
    <interface hosts="LoraMeshNetworkUrban25km.hybridGW3" names="eth0"
               address="10.1.3.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkUrban25km.gwRouter1" names="eth2"
               address="10.1.3.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW4 – Router eth3  (10.1.4.0/30)  quadrant NE: (3750,3750) -->
    <interface hosts="LoraMeshNetworkUrban25km.hybridGW4" names="eth0"
               address="10.1.4.1" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkUrban25km.gwRouter1" names="eth3"
               address="10.1.4.2" netmask="255.255.255.252"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- gwRouter1 → NetworkServer  (10.50.0.0/24) -->
    <interface hosts="LoraMeshNetworkUrban25km.gwRouter1"      names="eth4"
               address="10.50.0.1" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkUrban25km.networkServer"  names="eth0"
               address="10.50.0.2" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />
</config>
