<?xml version="1.0" encoding="UTF-8"?>
<!--
  network-config-city.xml  —  CityScale (10 GW) Backhaul IP Konfigürasyonu
  Her GW-Router linki için /30 subnet, statik varsayılan rotalar ile.
-->
<config>
    <!-- LoRaGWNic: sadece IP ata, rota yok (LoRa radyo yüzü) -->
    <interface hosts="**" names="LoRaGWNic"
               address="10.99.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- LoRaNic: EndNode LoRa arabirimi, rota yok -->
    <interface hosts="**" names="LoRaNic"
               address="10.98.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- WLAN: MeshNode kablosuz, rota yok -->
    <interface hosts="LoraMeshNetworkCity.meshNode*" names="wlan0"
               address="10.97.0.x" netmask="255.255.255.0"
               add-static-route="false" add-subnet-route="false"
               add-default-route="false" add-multicast-route="false" />

    <!-- GW1 – Router eth0/eth0  (10.1.1.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW1"  names="eth0" address="10.1.1.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth0" address="10.1.1.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW2 – Router eth1  (10.1.2.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW2"  names="eth0" address="10.1.2.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth1" address="10.1.2.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW3 – Router eth2  (10.1.3.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW3"  names="eth0" address="10.1.3.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth2" address="10.1.3.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW4 – Router eth3  (10.1.4.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW4"  names="eth0" address="10.1.4.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth3" address="10.1.4.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW5 – Router eth4  (10.1.5.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW5"  names="eth0" address="10.1.5.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth4" address="10.1.5.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW6 – Router eth5  (10.1.6.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW6"  names="eth0" address="10.1.6.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth5" address="10.1.6.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW7 – Router eth6  (10.1.7.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW7"  names="eth0" address="10.1.7.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth6" address="10.1.7.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW8 – Router eth7  (10.1.8.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW8"  names="eth0" address="10.1.8.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth7" address="10.1.8.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW9 – Router eth8  (10.1.9.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW9"  names="eth0" address="10.1.9.1"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth8" address="10.1.9.2"  netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- GW10 – Router eth9  (10.1.10.0/30) -->
    <interface hosts="LoraMeshNetworkCity.hybridGW10" names="eth0" address="10.1.10.1" netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.gwRouter1"  names="eth9" address="10.1.10.2" netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- Router – NS eth10  (10.1.11.0/30) -->
    <interface hosts="LoraMeshNetworkCity.gwRouter1"   names="eth10" address="10.1.11.1" netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />
    <interface hosts="LoraMeshNetworkCity.networkServer" names="eth0" address="10.1.11.2" netmask="255.255.255.252" add-static-route="false" add-subnet-route="false" add-default-route="false" add-multicast-route="false" />

    <!-- Statik varsayılan rotalar: her GW trafiğini gwRouter1 üzerinden iletir -->
    <route hosts="LoraMeshNetworkCity.hybridGW1"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW2"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW3"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW4"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW5"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW6"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW7"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW8"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW9"  destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.hybridGW10" destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
    <route hosts="LoraMeshNetworkCity.networkServer" destination="0.0.0.0" netmask="0.0.0.0" interface="eth0" />
</config>
